# -----------------------------------------------------------------------------
# FinSight CFO Production Environment Configuration Template
# -----------------------------------------------------------------------------
# Copy this file to `.env.production` or set these in your server environment.

# 1. Base App Configuration
APP_MODE=production
ALLOW_DEMO_FALLBACK=false
MARKET_WATCH_USE_FIXTURES=false
CORS_ALLOW_ORIGINS=https://your-production-app.com,https://api.your-production-app.com

# 2. Persistence / Database Configuration
# Options: 'database' (production) or 'local' (development memory/json fallback)
PERSISTENCE_BACKEND=database
DATABASE_URL=postgresql://db_user:db_password@db_host:5432/db_name
DATABASE_ECHO=false

# 3. Authentication Configuration
# AUTH_SECRET must be set to a secure, random string in production mode.
AUTH_MODE=production
AUTH_SECRET=your-randomly-generated-32-character-secret-key-here
AUTH_DEFAULT_ORGANIZATION_ID=org_production_default
AUTH_DEFAULT_USER_ID=user_production_default
AUTH_DEFAULT_ROLE=viewer
AUTH_ALLOW_HEADER_OVERRIDES=false

# 4. Job Queue Configuration (Redis)
# Options: 'redis' (production Celery/worker broker) or 'local'
QUEUE_BACKEND=redis
REDIS_URL=redis://:redis_password@redis_host:6379/0

# 5. External API / Provider Settings
FX_PROVIDER=frankfurter
FX_PROVIDER_BASE_URL=https://api.frankfurter.dev/v2
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key
COMMODITY_PROVIDER=fixture
HTTP_TIMEOUT_SECONDS=15

# 6. Cache Configuration
rates_ttl_seconds=21600
liquidity_ttl_seconds=21600

# 7. Frontend Vite Config
# Leave empty for same-origin (/api) routing through Nginx, or set to your API domain.
VITE_API_BASE_URL=
