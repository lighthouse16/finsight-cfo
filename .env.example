# ──────────────────────────────────────────────────────────
# Frontend (Vite)
# ──────────────────────────────────────────────────────────
# Frontend reads this through Vite's import.meta.env
# If not set, the frontend falls back to http://127.0.0.1:8000
#
# Docker (nginx reverse-proxy):
#   Leave empty or unset — nginx routes /api/* to the backend automatically.
#   The frontend fetches from the same origin, so no separate API base is needed.
#
# Local dev:
#   Set to the backend address (e.g. http://127.0.0.1:8000)
VITE_API_BASE_URL=http://127.0.0.1:8000

# Market Watch auto-refresh interval in seconds (frontend polls backend)
VITE_MARKET_WATCH_REFRESH_SECONDS=300

