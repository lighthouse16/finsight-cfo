# ──────────────────────────────────────────────────────────
# Frontend (Vite)
# ──────────────────────────────────────────────────────────
# Frontend reads this through Vite's import.meta.env
# If not set, the frontend falls back to http://127.0.0.1:8000
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_MARKET_WATCH_REFRESH_SECONDS=300

# Report Worker Harness Configurations (Safe-Off Defaults)
REPORT_WORKER_ENABLED=false
REPORT_WORKER_MAX_JOBS_PER_TICK=1
