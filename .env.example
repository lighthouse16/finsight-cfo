# ──────────────────────────────────────────────────────────
# Frontend (Vite)
# ──────────────────────────────────────────────────────────
# Vercel/judge demo:
#   Set this to the deployed backend origin, for example:
#   https://your-backend.onrender.com
# Local dev:
#   Set to the local FastAPI backend.
VITE_API_BASE_URL=http://127.0.0.1:8000

# ──────────────────────────────────────────────────────────
# Backend/runtime placeholders used by Docker Compose or split deploys
# ──────────────────────────────────────────────────────────
APP_MODE=production
ALLOW_DEMO_FALLBACK=false
MARKET_WATCH_USE_FIXTURES=true

# Comma-separated frontend origins allowed by backend CORS.
# Replace the Vercel placeholder with your deployed frontend URL.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-vercel-app.vercel.app

# ──────────────────────────────────────────────────────────
# AI CFO — LLM Provider Configurations
# ──────────────────────────────────────────────────────────
# Options: google_ai, openai, azure_openai, or empty for deterministic fallback.
LLM_PROVIDER=google_ai
GOOGLE_API_KEY=
GOOGLE_AI_MODEL=gemini-1.5-flash

# ──────────────────────────────────────────────────────────
# Optional local defaults retained for compose/development
# ──────────────────────────────────────────────────────────
VITE_MARKET_WATCH_REFRESH_SECONDS=300
PERSISTENCE_BACKEND=local
DATABASE_URL=sqlite:///./storage_db/finsight_dev.db
REPORT_WORKER_ENABLED=false
REPORT_WORKER_MAX_JOBS_PER_TICK=1
SCHEDULER_MODE=manual
OBJECT_STORAGE_BACKEND=local_file
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
QUEUE_BACKEND=in_process
QUEUE_REDIS_URL=redis://localhost:6379/0
AUTH_MODE=local
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
RATE_LIMIT_IP_RATE=10.0
RATE_LIMIT_IP_BURST=20.0
RATE_LIMIT_WS_RATE=50.0
RATE_LIMIT_WS_BURST=100.0
