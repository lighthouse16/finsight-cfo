# ──────────────────────────────────────────────────────────
# Backend (FastAPI)
# ──────────────────────────────────────────────────────────
#
# Docker Compose:
#   Copy this file to backend/.env and edit as needed.
#   The docker-compose.yml loads backend/.env automatically.
#   Defaults are safe for local development.
#
# Local dev:
#   copy backend\.env.example backend\.env
#   Then: .\.venv\Scripts\python.exe -m uvicorn app.main:app --reload --port 8000
# ──────────────────────────────────────────────────────────

# HKMA public API base URL
HKMA_BASE_URL=https://api.hkma.gov.hk/public

# Set to true to use local fixture data instead of upstream HKMA
# In Docker, this defaults to true (see docker-compose.yml)
MARKET_WATCH_USE_FIXTURES=true

# HTTP client timeout in seconds for upstream requests
HTTP_TIMEOUT_SECONDS=10

# Cache TTL for rates response in seconds (default 6 h)
RATES_TTL_SECONDS=21600

# Cache TTL for liquidity response in seconds (default 6 h)
LIQUIDITY_TTL_SECONDS=21600

# Live Data Foundation Configs
FX_PROVIDER=frankfurter
FX_PROVIDER_BASE_URL=https://api.frankfurter.dev/v2
ALPHA_VANTAGE_API_KEY=
COMMODITY_PROVIDER=fixture
MARKET_WATCH_AUTO_REFRESH_SECONDS=300
