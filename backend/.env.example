# ──────────────────────────────────────────────────────────
# Backend (FastAPI)
# ──────────────────────────────────────────────────────────
#
# Docker Compose:
#   Copy this file to backend/.env and edit as needed.
#   The docker-compose.yml loads backend/.env automatically.
#   Defaults are safe for local development.
#
# Local dev:
#   copy backend\.env.example backend\.env
#   Then: .\.venv\Scripts\python.exe -m uvicorn app.main:app --reload --port 8000
# ──────────────────────────────────────────────────────────

# Runtime mode. Use "production" for deployed commercial environments.
APP_MODE=production
APP_VERSION=1.0.0-rc1

# Demo/sample helpers must be disabled in production.
ALLOW_DEMO_FALLBACK=false

# Auth context mode. Keep "local" until a real identity provider is wired in.
AUTH_MODE=local

# Safe local/demo request context defaults.
AUTH_DEFAULT_ORGANIZATION_ID=demo-org
AUTH_DEFAULT_USER_ID=demo-user
# Default role for local/demo requests. Supported values: admin, analyst, viewer.
AUTH_DEFAULT_ROLE=admin

# Header overrides are intended for local/demo development only.
AUTH_ALLOW_HEADER_OVERRIDES=true

# HKMA public API base URL
HKMA_BASE_URL=https://api.hkma.gov.hk/public

# Set to true to use local fixture data instead of upstream HKMA
# In Docker, this defaults to true (see docker-compose.yml)
MARKET_WATCH_USE_FIXTURES=true

# HTTP client timeout in seconds for upstream requests
HTTP_TIMEOUT_SECONDS=10

# Cache TTL for rates response in seconds (default 6 h)
RATES_TTL_SECONDS=21600

# Cache TTL for liquidity response in seconds (default 6 h)
LIQUIDITY_TTL_SECONDS=21600

# Live Data Foundation Configs
FX_PROVIDER=frankfurter
FX_PROVIDER_BASE_URL=https://api.frankfurter.dev/v2
ALPHA_VANTAGE_API_KEY=
COMMODITY_PROVIDER=fixture
MARKET_WATCH_AUTO_REFRESH_SECONDS=300

# Comma-separated frontend origins allowed by CORS.
# Replace the Vercel placeholder with your deployed frontend URL.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-vercel-app.vercel.app
# Legacy fallback still supported if FRONTEND_ORIGINS is unset.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Report Worker Harness Configurations (Safe-Off Defaults)
REPORT_WORKER_ENABLED=false
REPORT_WORKER_MAX_JOBS_PER_TICK=1
SCHEDULER_MODE=manual

# Persistence and Database modes
PERSISTENCE_BACKEND=local
DATABASE_URL=sqlite:///./storage_db/finsight_dev.db

# ──────────────────────────────────────────────────────────
# Object Storage Configurations (S3 / MinIO)
# ──────────────────────────────────────────────────────────
OBJECT_STORAGE_BACKEND=local_file
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ──────────────────────────────────────────────────────────
# AI CFO — LLM Provider Configurations
# ──────────────────────────────────────────────────────────
# Options: google_ai, openai, azure_openai, or empty (deterministic fallback)
LLM_PROVIDER=google_ai
GOOGLE_API_KEY=
GOOGLE_AI_MODEL=gemini-1.5-flash
GOOGLE_AI_BASE_URL=

# ──────────────────────────────────────────────────────────
# Queue / Scheduler configurations
# ──────────────────────────────────────────────────────────
# Options: in_process, redis
QUEUE_BACKEND=in_process
QUEUE_REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────────────────
# Rate Limiting Configurations (Active in production mode only)
# ──────────────────────────────────────────────────────────
# Requests allowed per second per IP (tokens refilled per second)
RATE_LIMIT_IP_RATE=10.0
# Maximum burst allowance for IP bucket
RATE_LIMIT_IP_BURST=20.0
# Requests allowed per second per Workspace
RATE_LIMIT_WS_RATE=50.0
# Maximum burst allowance for Workspace bucket
RATE_LIMIT_WS_BURST=100.0
